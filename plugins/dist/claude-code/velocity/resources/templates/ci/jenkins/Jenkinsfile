// Velocity CI/CD Integration — Jenkins
//
// Copy this file to the root of your repository as `Jenkinsfile`.
// Configure a Jenkins pipeline job pointing to this file.
//
// What this pipeline does:
//   - Runs Velocity guardrail checks on every Pull Request / branch build
//   - Detects Tier 1 stack changes on merge to main and writes a regeneration notice
//   - Triggers a weekly Tier 2 scan notification (configure a separate Jenkins job
//     with a cron trigger: H 9 * * 1)
//
// Prerequisites:
//   1. Jenkins must have the Pipeline, Git, and Credentials plugins installed.
//   2. Add a Jenkins credential (Secret Text) named VELOCITY_GIT_TOKEN with write
//      access to this repository — needed for committing the regeneration notice.
//   3. Optionally set VELOCITY_WORKSPACE_URL as a Jenkins environment variable
//      if this repository is connected to a velocity-workspace.

pipeline {
    agent any

    options {
        timeout(time: 15, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '30'))
        skipDefaultCheckout(false)
    }

    environment {
        VELOCITY_BOT_NAME  = 'Velocity CI'
        VELOCITY_BOT_EMAIL = 'velocity-ci@noreply.jenkins'
    }

    stages {

        // ─────────────────────────────────────────────────────────────────
        // Stage 1: Guardrail Validation
        // Runs on all branches and PRs. Fails the build on guardrail violations.
        // ─────────────────────────────────────────────────────────────────
        stage('Velocity Guardrails') {
            when {
                // Run on PRs and feature branches, not on scheduled builds
                not { triggeredBy 'TimerTrigger' }
            }
            steps {
                script {
                    def guardrailConfig = fileExists('.velocity/guardrails/default.yaml')

                    if (!guardrailConfig) {
                        echo 'WARNING: No .velocity/guardrails/default.yaml found. Skipping Velocity guardrail checks.'
                        echo 'Run /setup in your AI coding assistant to initialize Velocity.'
                        return
                    }

                    // Determine the base branch for diff analysis
                    def baseBranch = env.CHANGE_TARGET ?: 'main'

                    sh """
                        echo '=== Velocity Guardrail Check 1: Vertical Slice ==='
                        CHANGED_FILES=\$(git diff --name-only origin/${baseBranch}...HEAD 2>/dev/null || git diff --name-only HEAD~1...HEAD)

                        HAS_MIGRATION=\$(echo "\$CHANGED_FILES" | grep -c 'migration\\|schema\\|flyway\\|liquibase\\|alembic' || true)
                        HAS_API=\$(echo "\$CHANGED_FILES" | grep -c 'controller\\|route\\|handler\\|resolver\\|endpoint\\|router' || true)
                        HAS_UI=\$(echo "\$CHANGED_FILES" | grep -c 'component\\|page\\|view\\|screen\\|\\.tsx\\|\\.jsx\\|\\.vue\\|\\.svelte' || true)
                        HAS_SERVICE=\$(echo "\$CHANGED_FILES" | grep -c 'service\\|domain\\|usecase\\|command\\|query\\|aggregate' || true)
                        HAS_TEST=\$(echo "\$CHANGED_FILES" | grep -c '\\.test\\.\\|\\.spec\\.\\|_test\\.\\|Test\\.' || true)

                        LAYER_COUNT=0
                        [ "\$HAS_MIGRATION" -gt 0 ] && LAYER_COUNT=\$((LAYER_COUNT + 1))
                        [ "\$HAS_API" -gt 0 ] && LAYER_COUNT=\$((LAYER_COUNT + 1))
                        [ "\$HAS_UI" -gt 0 ] && LAYER_COUNT=\$((LAYER_COUNT + 1))
                        [ "\$HAS_SERVICE" -gt 0 ] && LAYER_COUNT=\$((LAYER_COUNT + 1))

                        if [ "\$LAYER_COUNT" -eq 1 ] && [ "\$HAS_TEST" -eq 0 ]; then
                            echo 'FAIL: This build touches only one layer without tests.'
                            echo 'Velocity requires vertical slices. Add tests or span multiple layers in this PR.'
                            exit 1
                        fi
                        echo "PASS: Build spans \$LAYER_COUNT layers."
                    """

                    sh """
                        echo '=== Velocity Guardrail Check 2: Secrets Scan ==='
                        DIFF=\$(git diff origin/${baseBranch}...HEAD 2>/dev/null || git diff HEAD~1...HEAD)
                        if echo "\$DIFF" | grep -qiE '(api_key|secret_key|aws_secret|private_key|password|token)\\s*[:=]\\s*["'"'"'][A-Za-z0-9+/]{20,}'; then
                            echo 'FAIL: Potential secret detected in diff.'
                            echo 'Secrets must not be committed. Use environment variables or a secrets manager.'
                            exit 1
                        fi
                        echo 'PASS: No obvious secrets detected.'
                    """

                    sh """
                        echo '=== Velocity Guardrail Check 3: Breaking Change Detection ==='
                        DIFF=\$(git diff origin/${baseBranch}...HEAD 2>/dev/null || git diff HEAD~1...HEAD)

                        REMOVED_ROUTES=\$(echo "\$DIFF" | grep -E '^\\-.*(@(Get|Post|Put|Delete|Patch)Mapping|app\\.(get|post|put|delete|patch)\\(|router\\.(get|post|put|delete|patch)\\()' || true)
                        DROPPED_COLUMNS=\$(echo "\$DIFF" | grep -iE '^\\+.*(drop\\s+column|drop_column|remove_column)' || true)

                        if [ -n "\$REMOVED_ROUTES" ]; then
                            echo 'WARNING: Possible route removal detected.'
                            echo "\$REMOVED_ROUTES" | head -5
                            echo 'If this is an API breaking change, bump the API version (/v2/) and keep the old endpoint.'
                        fi

                        if [ -n "\$DROPPED_COLUMNS" ]; then
                            echo 'WARNING: Column drop detected in migration.'
                            echo "\$DROPPED_COLUMNS" | head -5
                            echo 'Ensure a down migration exists and all consumers are updated in this PR.'
                        fi

                        if [ -z "\$REMOVED_ROUTES" ] && [ -z "\$DROPPED_COLUMNS" ]; then
                            echo 'PASS: No obvious breaking changes detected.'
                        fi
                    """

                    sh """
                        echo '=== Velocity Guardrail Check 4: API Versioning ==='
                        DIFF=\$(git diff origin/${baseBranch}...HEAD 2>/dev/null || git diff HEAD~1...HEAD)
                        NEW_ENDPOINTS=\$(echo "\$DIFF" | grep -E '^\\+.*(@(Get|Post|Put|Delete|Patch)Mapping|app\\.(get|post|put|delete|patch)\\()' || true)

                        if [ -n "\$NEW_ENDPOINTS" ]; then
                            UNVERSIONED=\$(echo "\$NEW_ENDPOINTS" | grep -v '/v[0-9]/' || true)
                            if [ -n "\$UNVERSIONED" ]; then
                                echo 'WARNING: New API endpoints may be missing version prefix (/v1/, /v2/, etc.):'
                                echo "\$UNVERSIONED" | head -5
                            else
                                echo 'PASS: All new endpoints appear to be versioned.'
                            fi
                        else
                            echo 'PASS: No new API endpoints detected.'
                        fi
                    """
                }
            }
            post {
                failure {
                    echo 'Velocity guardrail checks FAILED. Review the output above for remediation steps.'
                }
                success {
                    echo 'Velocity guardrail checks PASSED.'
                }
            }
        }

        // ─────────────────────────────────────────────────────────────────
        // Stage 2: Tier 1 Regeneration Notice
        // Runs only on push to main/master. Writes a notice when qualifying
        // dependency or structural changes are detected.
        // ─────────────────────────────────────────────────────────────────
        stage('Velocity Regeneration Notice') {
            when {
                anyOf {
                    branch 'main'
                    branch 'master'
                }
                not { changeRequest() }
                not { triggeredBy 'TimerTrigger' }
            }
            steps {
                withCredentials([string(credentialsId: 'VELOCITY_GIT_TOKEN', variable: 'GIT_TOKEN')]) {
                    sh '''
                        CHANGED=$(git diff --name-only HEAD~1...HEAD 2>/dev/null || echo "")

                        DEPENDENCY_CHANGE=false
                        STRUCTURAL_CHANGE=false
                        GUARDRAIL_CHANGE=false
                        CONTEXT_CHANGE=false

                        echo "$CHANGED" | grep -qE "^(package\\.json|pom\\.xml|go\\.mod|requirements\\.txt|Gemfile|Cargo\\.toml|build\\.gradle|pyproject\\.toml)" \
                            && DEPENDENCY_CHANGE=true || true
                        echo "$CHANGED" | grep -qE "^(services/|apps/|packages/)" \
                            && STRUCTURAL_CHANGE=true || true
                        echo "$CHANGED" | grep -q "CONTEXT\\.md" \
                            && CONTEXT_CHANGE=true || true
                        echo "$CHANGED" | grep -q "^\\.velocity/artifacts/adrs/" \
                            && CONTEXT_CHANGE=true || true
                        echo "$CHANGED" | grep -q "^\\.velocity/guardrails/" \
                            && GUARDRAIL_CHANGE=true || true

                        echo "Velocity Tier 1 trigger detection:"
                        echo "  Dependency change:  $DEPENDENCY_CHANGE"
                        echo "  Structural change:  $STRUCTURAL_CHANGE"
                        echo "  Guardrail change:   $GUARDRAIL_CHANGE"
                        echo "  Context/ADR change: $CONTEXT_CHANGE"

                        if $DEPENDENCY_CHANGE || $STRUCTURAL_CHANGE || $GUARDRAIL_CHANGE || $CONTEXT_CHANGE; then
                            echo ""
                            echo "Qualifying Tier 1 change detected. Writing regeneration notice."

                            mkdir -p .velocity
                            cat > .velocity/REGEN_NOTICE.md << EOF
# Velocity Regeneration Notice

**Triggered:** $(date -u +"%Y-%m-%dT%H:%M:%SZ")
**Commit:** ${GIT_COMMIT}
**Build:** ${BUILD_URL}

## Trigger Reasons

$([ "$DEPENDENCY_CHANGE" = "true" ] && echo "- Dependency manifest changed")
$([ "$STRUCTURAL_CHANGE" = "true" ] && echo "- Structural change (new service/module directory)")
$([ "$GUARDRAIL_CHANGE" = "true" ] && echo "- Guardrail configuration changed")
$([ "$CONTEXT_CHANGE" = "true" ] && echo "- CONTEXT.md or ADR changed")

## Action Required

Run \`/sync\` in your AI coding assistant to regenerate Velocity assets.

Until you run \`/sync\`:
- Agents may be operating with stale stack awareness
- Guardrail changes are not yet reflected in hooks.json
- New domain terms are not yet injected into agent system prompts

This notice will be removed after the next successful \`/sync\` run.
EOF

                            git config user.name "$VELOCITY_BOT_NAME"
                            git config user.email "$VELOCITY_BOT_EMAIL"

                            REMOTE_URL=$(git remote get-url origin)
                            # Inject token into HTTPS remote URL
                            AUTHED_URL=$(echo "$REMOTE_URL" | sed "s|https://|https://velocity-ci:${GIT_TOKEN}@|")
                            git remote set-url origin "$AUTHED_URL"

                            git add .velocity/REGEN_NOTICE.md
                            git diff --staged --quiet || git commit -m "chore: Velocity regeneration notice — Tier 1 trigger detected [skip ci]"
                            git push origin HEAD:${BRANCH_NAME}
                        else
                            echo "No qualifying Tier 1 changes detected. Skipping regeneration notice."
                        fi
                    '''
                }
            }
        }

        // ─────────────────────────────────────────────────────────────────
        // Stage 3: Tier 2 Scan Notification
        // This stage is intended for use in a dedicated scheduled Jenkins job.
        // Create a separate job with a weekly trigger: H 9 * * 1
        // ─────────────────────────────────────────────────────────────────
        stage('Velocity Tier 2 Scan') {
            when {
                triggeredBy 'TimerTrigger'
            }
            steps {
                sh '''
                    echo "Velocity weekly Tier 2 scan"
                    echo ""
                    echo "Tier 2 signals require semantic analysis and cannot be detected by file diff alone."
                    echo ""
                    echo "Run /sync in your AI coding assistant to perform the full semantic re-scan."
                    echo ""
                    echo "Tier 2 signals to check for:"
                    echo "  - New API style adopted (REST → GraphQL, REST → gRPC)"
                    echo "  - New messaging pattern (first Kafka producer/consumer added)"
                    echo "  - New persistence layer (SQL → NoSQL)"
                    echo "  - New architectural pattern (first event sourcing aggregate)"
                    echo "  - Significant CONTEXT.md growth"
                    echo "  - New test framework adopted"
                    echo ""
                    echo "If significant changes are found, Velocity will update agents and skills on /sync."
                '''
            }
        }
    }

    post {
        always {
            echo 'Velocity pipeline complete.'
        }
        failure {
            echo 'Build failed. Check Velocity guardrail output for remediation instructions.'
        }
    }
}

// ─────────────────────────────────────────────────────────────────────────────
// Scheduling:
//
// For Tier 2 weekly scan, create a SEPARATE Jenkins job:
//   - Use this same Jenkinsfile
//   - Set a Build Trigger: Build periodically with cron: H 9 * * 1 (Monday 9am)
//   - The 'Velocity Tier 2 Scan' stage will run and all others will be skipped
//     via the `triggeredBy 'TimerTrigger'` condition.
// ─────────────────────────────────────────────────────────────────────────────
