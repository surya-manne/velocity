# OS
.DS_Store
Thumbs.db

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/

# TypeScript
*.tsbuildinfo
.tsbuildinfo

# Editor / tooling
.idea/
*.swp
.cache/
*.tmp
*.temp

# Build outputs
docs-site/.vitepress/dist/
docs-site/.vitepress/cache/
packages/vscode-extension/dist/
packages/vscode-extension/out/

# Plugin bundles (CI-generated)
plugins/dist/

# Plugin builder temp (staging dir used by `npm run check`)
.plugin-build-check/

# Root and docs-site lockfiles are platform-specific (rollup native modules).
# packages/plugin-builder and packages/vscode-extension lockfiles ARE committed
# because their CI workflows use `npm ci` and don't have native module issues.
package-lock.json
docs-site/package-lock.json

# VS Code extension packages
packages/vscode-extension/*.vsix

# Velocity runtime / temp
.velocity/artifacts/ralph/
.velocity/artifacts/context/
.velocity/artifacts/handoffs/
.velocity/artifacts/approvals/
.velocity/artifacts/audit/
.velocity/install/

# Plans (feature execution artifacts)
plans/

# Logs
*.log

# Environment
.env
.env.*
!.env.example
