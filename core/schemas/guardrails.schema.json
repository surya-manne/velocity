{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://velocity.dev/schemas/guardrails.schema.json",
  "title": "GuardrailsConfig",
  "description": "Velocity guardrail configuration for a repository",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "enum": ["2.0"]
    },
    "quality": {
      "type": "object",
      "description": "Code quality gates",
      "properties": {
        "test_coverage_minimum": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "default": 80,
          "description": "Minimum test coverage percentage required"
        },
        "tdd_loop_required": {
          "type": "boolean",
          "default": true,
          "description": "Implementation tasks must follow red-green-refactor"
        },
        "documentation_required": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "architecture": {
      "type": "object",
      "description": "Architectural constraints",
      "properties": {
        "vertical_slice_required": {
          "type": "boolean",
          "default": true,
          "description": "All feature work must be delivered as vertical slices"
        },
        "horizontal_layer_pr_blocked": {
          "type": "boolean",
          "default": true,
          "description": "Block PRs that touch only one layer (pure DB, pure API, pure UI)"
        },
        "slice_has_tests_at_all_layers": {
          "type": "boolean",
          "default": true
        },
        "slice_acceptance_criteria_required": {
          "type": "boolean",
          "default": true
        },
        "tracer_bullet_first_required": {
          "type": "boolean",
          "default": true,
          "description": "First PR for a feature must be a minimal tracer, not a full build"
        },
        "context_window_reset_between_slices": {
          "type": "boolean",
          "default": true,
          "description": "Each slice must start in a fresh context window"
        },
        "handoff_artifact_required_per_slice": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "domain_language": {
      "type": "object",
      "description": "CONTEXT.md consistency enforcement",
      "properties": {
        "context_md_term_consistency": {
          "type": "boolean",
          "default": true,
          "description": "Variable/file/API names must match CONTEXT.md glossary"
        },
        "language_drift_detection": {
          "type": "boolean",
          "default": true,
          "description": "Flag new terms not present in CONTEXT.md"
        }
      }
    },
    "security": {
      "type": "object",
      "description": "Security gates",
      "properties": {
        "security_review_required": {
          "type": "boolean",
          "default": true
        },
        "secrets_scan_required": {
          "type": "boolean",
          "default": true
        },
        "dependency_vulnerability_scan": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "api": {
      "type": "object",
      "description": "API governance",
      "properties": {
        "api_versioning_required": {
          "type": "boolean",
          "default": true
        },
        "breaking_change_approval_required": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "feedback_loops": {
      "type": "object",
      "description": "Deterministic feedback loops enforced inside agent sessions",
      "properties": {
        "typecheck_on_every_generated_file": {
          "type": "boolean",
          "default": true
        },
        "test_after_every_red_green_cycle": {
          "type": "boolean",
          "default": true
        },
        "lint_before_commit": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "module_architecture": {
      "type": "object",
      "description": "Deep modules doctrine enforcement (Slice 4 — TDD + Deep Modules)",
      "properties": {
        "deep_module_enforcement": {
          "type": "boolean",
          "default": true,
          "description": "Enforce the deep modules doctrine during TDD refactor steps: simple interface, complex implementation"
        },
        "shallow_module_detection": {
          "type": "boolean",
          "default": true,
          "description": "Flag shallow module anti-patterns (utils directories, single-caller extractions, leaking complexity) as architecture debt"
        },
        "context_md_term_consistency": {
          "type": "boolean",
          "default": true,
          "description": "Validate variable, file, and function names against CONTEXT.md glossary during TDD refactor step"
        }
      }
    },
    "pre_tool_use_hooks": {
      "type": "array",
      "description": "Hooks that block dangerous agent actions before they execute",
      "items": {
        "type": "object",
        "required": ["event", "tool", "pattern", "action", "message"],
        "properties": {
          "event": { "type": "string", "enum": ["PreToolUse", "PostToolUse"] },
          "tool": { "type": "string" },
          "pattern": {
            "type": "string",
            "description": "Regex pattern matching the dangerous command"
          },
          "action": { "type": "string", "enum": ["block", "warn"] },
          "message": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
